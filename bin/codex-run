#!/usr/bin/env bash
# codex-run — hardened `codex exec` dispatch.
#
# It protects long runs against three common failure modes:
#   1. Sandbox git failures in linked worktrees: the git common directory is
#      added to workspace-write's writable roots.
#   2. Transient capacity, authentication, rate-limit, and stream failures:
#      retries use linear backoff. Content-filter blocks fail immediately.
#   3. Lost uncommitted work after a kill or crash: an EXIT/INT/TERM trap
#      snapshots tracked and untracked changes to refs/codex-salvage/* with a
#      temporary index and commit-tree. HEAD, the branch, the real index, and
#      the worktree remain untouched.
#
# Usage:
#   codex-run -H <codex_home> -m <model> -C <workdir> -p <prompt_file> -o <out_file> \
#             [-s read-only|workspace-write] [-b <salvage_branch>] \
#             [-R <salvage_remote>] [-r <max_retries>] [-e <effort>]
#
# A salvage branch push fires on every exit, including success. For a public
# remote, omit -b or use -R with a private recovery remote until work is reviewed.
set -u

CODEX_HOME_ARG="" MODEL="" WORKDIR="" PROMPT_FILE="" OUT_FILE="" EFFORT=""
SANDBOX="workspace-write" SALVAGE_BRANCH="" SALVAGE_REMOTE="origin" MAX_RETRIES=2
while getopts "H:m:C:p:o:s:b:R:r:e:" opt; do
  case "$opt" in
    H) CODEX_HOME_ARG=$OPTARG ;;
    m) MODEL=$OPTARG ;;
    C) WORKDIR=$OPTARG ;;
    p) PROMPT_FILE=$OPTARG ;;
    o) OUT_FILE=$OPTARG ;;
    s) SANDBOX=$OPTARG ;;
    b) SALVAGE_BRANCH=$OPTARG ;;
    R) SALVAGE_REMOTE=$OPTARG ;;
    r) MAX_RETRIES=$OPTARG ;;
    e) EFFORT=$OPTARG ;;
    *) exit 2 ;;
  esac
done
for req in CODEX_HOME_ARG MODEL WORKDIR PROMPT_FILE OUT_FILE; do
  [ -n "${!req}" ] || { echo "codex-run: missing -${req:0:1}" >&2; exit 2; }
done
[ -f "$PROMPT_FILE" ] || { echo "codex-run: prompt file not found: $PROMPT_FILE" >&2; exit 2; }
ERR_FILE="${OUT_FILE%.md}.err.log"

salvage() {
  git -C "$WORKDIR" rev-parse --git-dir >/dev/null 2>&1 || return 0
  local salvage_sha=""
  if [ -n "$(git -C "$WORKDIR" status --porcelain 2>/dev/null)" ]; then
    local gitdir tmpidx tree parent branch ts ref
    gitdir=$(git -C "$WORKDIR" rev-parse --absolute-git-dir 2>/dev/null)
    parent=$(git -C "$WORKDIR" rev-parse --verify HEAD 2>/dev/null)
    if [ -n "$gitdir" ] && [ -n "$parent" ]; then
      tmpidx="$gitdir/codex-salvage-index.$$"
      # Snapshot through a temporary index; never mutate the user's index.
      if GIT_INDEX_FILE="$tmpidx" git -C "$WORKDIR" read-tree "$parent" 2>/dev/null \
         && GIT_INDEX_FILE="$tmpidx" git -C "$WORKDIR" add -A 2>/dev/null; then
        tree=$(GIT_INDEX_FILE="$tmpidx" git -C "$WORKDIR" write-tree 2>/dev/null)
        if [ -n "$tree" ]; then
          salvage_sha=$(git -C "$WORKDIR" commit-tree "$tree" -p "$parent" \
            -m "WIP salvage: codex-run auto-commit (model=$MODEL)" 2>/dev/null)
        fi
      fi
      rm -f "$tmpidx"
      if [ -n "$salvage_sha" ]; then
        branch=$(git -C "$WORKDIR" rev-parse --abbrev-ref HEAD 2>/dev/null || echo detached)
        ts=$(date +%Y%m%d-%H%M%S)
        ref="refs/codex-salvage/${branch//\//-}-$ts-$$"
        git -C "$WORKDIR" update-ref "$ref" "$salvage_sha" 2>/dev/null \
          && echo "codex-run: salvaged dirty state → $ref ($(git -C "$WORKDIR" rev-parse --short "$salvage_sha")); branch/worktree untouched" >&2
      else
        echo "codex-run: WARNING dirty state present but salvage snapshot failed (unborn HEAD?) — worktree left as-is" >&2
      fi
    fi
  fi
  if [ -n "$SALVAGE_BRANCH" ]; then
    local push_src="${salvage_sha:-HEAD}"
    git -C "$WORKDIR" push -qf "$SALVAGE_REMOTE" "$push_src:refs/heads/$SALVAGE_BRANCH" 2>/dev/null \
      && echo "codex-run: pushed $push_src → $SALVAGE_REMOTE/$SALVAGE_BRANCH" >&2
  fi
}
trap salvage EXIT
trap 'salvage; exit 130' INT
trap 'salvage; exit 143' TERM

# Sandbox-safe git: expose a linked worktree's git common directory for writes.
EXTRA_CFG=()
[ -n "$EFFORT" ] && EXTRA_CFG+=(-c "model_reasoning_effort=\"$EFFORT\"")
if [ "$SANDBOX" = "workspace-write" ]; then
  COMMON_DIR=$(git -C "$WORKDIR" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)
  [ -n "$COMMON_DIR" ] && EXTRA_CFG+=(-c "sandbox_workspace_write.writable_roots=[\"$COMMON_DIR\"]")
fi

attempt=0
while :; do
  attempt=$((attempt + 1))
  : > "$OUT_FILE"
  CODEX_HOME="$CODEX_HOME_ARG" codex exec --skip-git-repo-check --color never \
    --sandbox "$SANDBOX" ${EXTRA_CFG[@]+"${EXTRA_CFG[@]}"} -m "$MODEL" -C "$WORKDIR" -o "$OUT_FILE" \
    "$(cat "$PROMPT_FILE")" </dev/null >/dev/null 2>"$ERR_FILE"
  rc=$?
  [ $rc -eq 0 ] && [ -s "$OUT_FILE" ] && { echo "codex-run: OK attempt=$attempt bytes=$(wc -c <"$OUT_FILE" | tr -d ' ')"; exit 0; }

  if grep -qiE "content filter|trusted access|can('|’)t (help|assist) with" "$ERR_FILE"; then
    echo "codex-run: CONTENT-FILTERED — rewrite the prompt defensively (audit/verify framing, not construct/exploit). Not retrying." >&2
    exit 3
  fi
  if [ $attempt -le $MAX_RETRIES ] && grep -qiE "capacity|401|unauthorized|rate limit|too many requests|disconnect|overloaded|timed? ?out|temporarily" "$ERR_FILE"; then
    wait_s=$((60 * attempt))
    echo "codex-run: transient failure (rc=$rc), retry $attempt/$MAX_RETRIES in ${wait_s}s: $(grep -m1 -ioE 'capacity|401|unauthorized|rate limit|too many requests|disconnect|overloaded|timed? ?out' "$ERR_FILE")" >&2
    sleep "$wait_s"
    continue
  fi
  echo "codex-run: FAILED rc=$rc attempt=$attempt (out_bytes=$(wc -c <"$OUT_FILE" | tr -d ' ')); stderr tail:" >&2
  tail -3 "$ERR_FILE" >&2
  [ "$rc" -eq 0 ] && rc=1
  exit "$rc"
done
