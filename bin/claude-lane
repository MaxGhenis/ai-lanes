#!/usr/bin/env bash
# claude-lane — hardened headless Claude Code dispatch pinned to an enrolled
# account lane.
#
# It hardens four failure modes:
#   1. Transient 5xx/429/capacity/network failures retry with backoff. Hard
#      account limits repick immediately with -A or fail pinned runs with rc=4.
#   2. Revoked or expired setup tokens fail immediately with rc=5.
#   3. EXIT/INT/TERM snapshot dirty state to refs/claude-salvage/* through a
#      temporary index and commit-tree without touching HEAD, the branch, the
#      real index, or the worktree.
#   4. The completed session transcript's per-message model field is checked
#      for silent model downgrades. A mismatch emits a warning and creates a
#      .DOWNGRADED marker beside the output.
#
# Usage:
#   claude-lane -a <email> | -A -C <workdir> -p <prompt_file> -o <out_file> \
#               [-m <model>] [-s workspace-write|read-only] \
#               [-b <salvage_branch>] [-R <salvage_remote>] \
#               [-r <max_retries>] [-d]
#
# A salvage branch push fires on every exit, including success. For a public
# remote, omit -b or use -R with a private recovery remote until work is reviewed.
set -u

ORIG_ARGS=("$@")
EMAIL="" AUTO=0 MODEL="claude-fable-5" WORKDIR="" PROMPT_FILE="" OUT_FILE=""
SANDBOX="workspace-write" SALVAGE_BRANCH="" SALVAGE_REMOTE="origin" MAX_RETRIES=2 DETACH=0
while getopts "a:Am:C:p:o:s:b:R:r:d" opt; do
  case "$opt" in
    a) EMAIL=$OPTARG ;;
    A) AUTO=1 ;;
    m) MODEL=$OPTARG ;;
    C) WORKDIR=$OPTARG ;;
    p) PROMPT_FILE=$OPTARG ;;
    o) OUT_FILE=$OPTARG ;;
    s) SANDBOX=$OPTARG ;;
    b) SALVAGE_BRANCH=$OPTARG ;;
    R) SALVAGE_REMOTE=$OPTARG ;;
    r) MAX_RETRIES=$OPTARG ;;
    d) DETACH=1 ;;
    *) exit 2 ;;
  esac
done
[ -n "$EMAIL" ] || [ "$AUTO" = 1 ] || { echo "claude-lane: need -a <email> or -A" >&2; exit 2; }
[ -n "$WORKDIR" ] || { echo "claude-lane: missing -C <workdir>" >&2; exit 2; }
[ -n "$PROMPT_FILE" ] || { echo "claude-lane: missing -p <prompt_file>" >&2; exit 2; }
[ -n "$OUT_FILE" ] || { echo "claude-lane: missing -o <out_file>" >&2; exit 2; }
[ -d "$WORKDIR" ] || { echo "claude-lane: workdir not found: $WORKDIR" >&2; exit 2; }
[ -f "$PROMPT_FILE" ] || { echo "claude-lane: prompt file not found: $PROMPT_FILE" >&2; exit 2; }
case "$SANDBOX" in
  workspace-write|read-only) ;;
  *) echo "claude-lane: -s must be workspace-write or read-only" >&2; exit 2 ;;
esac
command -v jq >/dev/null || { echo "claude-lane: jq required" >&2; exit 2; }
command -v uuidgen >/dev/null || { echo "claude-lane: uuidgen required" >&2; exit 2; }

SCRIPT_DIR=$(CDPATH='' cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
CLAUDE_BIN=${CLAUDE_LANE_CLAUDE:-claude}
AI_LANES_BIN=${CLAUDE_LANE_AI_LANES:-$SCRIPT_DIR/ai-lanes}
if [ ! -x "$AI_LANES_BIN" ]; then
  AI_LANES_BIN=$(command -v "$AI_LANES_BIN" 2>/dev/null || command -v ai-lanes || true)
fi
CLAUDE_PICK=${CLAUDE_LANE_PICK:-$SCRIPT_DIR/claude-pick}
if [ ! -x "$CLAUDE_PICK" ]; then
  CLAUDE_PICK=$(command -v "$CLAUDE_PICK" 2>/dev/null || command -v claude-pick || true)
fi
CLAUDE_MODEL_BIN=""
if [ -n "${CLAUDE_LANE_CLAUDE_MODEL:-}" ]; then
  CLAUDE_MODEL_BIN=$(command -v "$CLAUDE_LANE_CLAUDE_MODEL" 2>/dev/null || true)
fi
CLAUDE_DIR=${CLAUDE_LANE_CLAUDE_DIR:-${AI_LANES_CLAUDE_DIR:-$HOME/.claude}}
BACKOFF_BASE=${CLAUDE_LANE_BACKOFF:-60}

BASE="${OUT_FILE%.md}"
ERR_FILE="$BASE.err.log"
RAW_FILE="$BASE.result.json"
LANE_LOG="$BASE.lane.log"

if [ "$DETACH" = 1 ] && [ -z "${CLAUDE_LANE_DETACHED:-}" ]; then
  export CLAUDE_LANE_DETACHED=1
  nohup "$0" ${ORIG_ARGS[@]+"${ORIG_ARGS[@]}"} </dev/null >>"$LANE_LOG" 2>&1 &
  pid=$!
  disown "$pid" 2>/dev/null || true
  echo "claude-lane: detached pid=$pid · log=$LANE_LOG · out=$OUT_FILE"
  exit 0
fi

salvage() {
  git -C "$WORKDIR" rev-parse --git-dir >/dev/null 2>&1 || return 0
  local salvage_sha=""
  if [ -n "$(git -C "$WORKDIR" status --porcelain 2>/dev/null)" ]; then
    local gitdir tmpidx tree parent branch ts ref
    gitdir=$(git -C "$WORKDIR" rev-parse --absolute-git-dir 2>/dev/null)
    parent=$(git -C "$WORKDIR" rev-parse --verify HEAD 2>/dev/null)
    if [ -n "$gitdir" ] && [ -n "$parent" ]; then
      tmpidx="$gitdir/claude-salvage-index.$$"
      if GIT_INDEX_FILE="$tmpidx" git -C "$WORKDIR" read-tree "$parent" 2>/dev/null \
         && GIT_INDEX_FILE="$tmpidx" git -C "$WORKDIR" add -A 2>/dev/null; then
        tree=$(GIT_INDEX_FILE="$tmpidx" git -C "$WORKDIR" write-tree 2>/dev/null)
        if [ -n "$tree" ]; then
          salvage_sha=$(git -C "$WORKDIR" commit-tree "$tree" -p "$parent" \
            -m "WIP salvage: claude-lane auto-commit (lane=${EMAIL:-unpicked} model=$MODEL)" 2>/dev/null)
        fi
      fi
      rm -f "$tmpidx"
      if [ -n "$salvage_sha" ]; then
        branch=$(git -C "$WORKDIR" rev-parse --abbrev-ref HEAD 2>/dev/null || echo detached)
        ts=$(date +%Y%m%d-%H%M%S)
        ref="refs/claude-salvage/${branch//\//-}-$ts-$$"
        git -C "$WORKDIR" update-ref "$ref" "$salvage_sha" 2>/dev/null \
          && echo "claude-lane: salvaged dirty state → $ref ($(git -C "$WORKDIR" rev-parse --short "$salvage_sha")); branch/worktree untouched" >&2
      else
        echo "claude-lane: WARNING dirty state present but salvage snapshot failed (unborn HEAD?) — worktree left as-is" >&2
      fi
    fi
  fi
  if [ -n "$SALVAGE_BRANCH" ]; then
    local push_src="${salvage_sha:-HEAD}"
    git -C "$WORKDIR" push -qf "$SALVAGE_REMOTE" "$push_src:refs/heads/$SALVAGE_BRANCH" 2>/dev/null \
      && echo "claude-lane: pushed $push_src → $SALVAGE_REMOTE/$SALVAGE_BRANCH" >&2
  fi
}
trap salvage EXIT
trap 'salvage; exit 130' INT
trap 'salvage; exit 143' TERM

pick_lane() {
  local picked
  [ -n "$CLAUDE_PICK" ] || return 1
  picked=$("$CLAUDE_PICK") || return 1
  [ -n "$picked" ] || return 1
  EMAIL=$picked
}

fetch_token() {
  [ -n "$AI_LANES_BIN" ] || {
    echo "claude-lane: ai-lanes command not found" >&2
    return 1
  }
  TOKEN=$("$AI_LANES_BIN" secret get-for-account "$EMAIL" 2>/dev/null)
  if [ -z "$TOKEN" ]; then
    echo "claude-lane: no stored setup token for $EMAIL" >&2
    echo "claude-lane: run claude setup-token while signed into $EMAIL" >&2
    echo "claude-lane: then run ai-lanes enroll $EMAIL" >&2
    return 1
  fi
}

inline_model_report() {
  local project_key project_dir transcript models latest refusals
  project_key=$( (cd "$WORKDIR" && printf '%s' "$PWD" | tr '/.' '--') )
  project_dir="$CLAUDE_DIR/projects/$project_key"
  transcript="$project_dir/$SID.jsonl"
  [ -f "$transcript" ] || {
    echo "no transcript at $transcript" >&2
    return 2
  }
  models=$(jq -r 'select(.type=="assistant") | .message.model' "$transcript" 2>/dev/null \
    | grep -v '^null$' | tail -10)
  [ -n "$models" ] || {
    echo "no assistant turns in $transcript" >&2
    return 2
  }
  latest=$(printf '%s\n' "$models" | tail -1)
  refusals=$(grep -c '"stop_reason":"refusal"' "$transcript" 2>/dev/null || true)
  echo "transcript: $transcript"
  echo "last 10 assistant turns:"
  printf '%s\n' "$models" | sort | uniq -c | sort -rn | awk '{printf "  %s x%s\n", $2, $1}'
  echo "refusal fallbacks in session: ${refusals:-0}"
  echo "latest: $latest"
}

# The transcript field is the ground truth for the model that served the lane.
check_model() {
  local report latest
  if [ -n "${CLAUDE_LANE_CLAUDE_MODEL:-}" ] && [ -z "$CLAUDE_MODEL_BIN" ]; then
    echo "claude-lane: configured model checker not found — skipping served-model check" >&2
    return 0
  fi
  if [ -n "$CLAUDE_MODEL_BIN" ]; then
    report=$( (cd "$WORKDIR" && "$CLAUDE_MODEL_BIN" -n 10 "$SID") 2>&1 )
  else
    report=$(inline_model_report 2>&1)
  fi
  latest=$(printf '%s\n' "$report" | sed -n 's/^latest: //p' | tail -1)
  if [ -z "$latest" ]; then
    echo "claude-lane: served-model check inconclusive (no transcript for session $SID?)" >&2
    return 0
  fi
  case "$latest" in
    "$MODEL"|*"$MODEL"*)
      echo "claude-lane: served by $latest (as requested)" >&2 ;;
    *)
      {
        echo "claude-lane: MODEL-DOWNGRADE — lane served $latest, requested $MODEL (classifier fallback)."
        echo "claude-lane: treat judgment or writing output as unverified and re-check it before use."
        printf '%s\n' "$report"
      } | tee "$BASE.DOWNGRADED" >&2 ;;
  esac
}

if [ "$AUTO" = 1 ] && [ -z "$EMAIL" ]; then
  pick_lane || { echo "claude-lane: no dispatchable lane" >&2; exit 1; }
fi
fetch_token || exit 2

attempt=0
while :; do
  attempt=$((attempt + 1))
  SID=$(uuidgen | tr '[:upper:]' '[:lower:]')
  : > "$OUT_FILE"
  : > "$RAW_FILE"
  PERM_ARGS=()
  [ "$SANDBOX" = "workspace-write" ] && PERM_ARGS=(--dangerously-skip-permissions)
  (
    cd "$WORKDIR" || exit 97
    # Pin subscription OAuth and prevent accidental API-meter billing.
    unset ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN
    CLAUDE_CODE_OAUTH_TOKEN="$TOKEN" exec "$CLAUDE_BIN" -p --model "$MODEL" \
      --session-id "$SID" --output-format json ${PERM_ARGS[@]+"${PERM_ARGS[@]}"}
  ) <"$PROMPT_FILE" >"$RAW_FILE" 2>"$ERR_FILE"
  rc=$?

  if [ $rc -eq 0 ] && [ -s "$RAW_FILE" ] && [ "$(jq -r \
      'if type=="object" and .is_error==false and (.result|type=="string" and length>0) then "ok" else "bad" end' \
      "$RAW_FILE" 2>/dev/null)" = "ok" ]; then
    jq -r '.result' "$RAW_FILE" > "$OUT_FILE"
    if [ -s "$OUT_FILE" ]; then
      echo "claude-lane: OK lane=$EMAIL model=$MODEL attempt=$attempt bytes=$(wc -c <"$OUT_FILE" | tr -d ' ') session=$SID"
      check_model
      exit 0
    fi
  fi

  ERRTXT=("$ERR_FILE")
  [ -s "$RAW_FILE" ] && ERRTXT=("$ERR_FILE" "$RAW_FILE")
  if grep -qiE "401|unauthoriz|authentication_error|oauth token|token.*(revoked|expired)|invalid.*api.?key" \
      ${ERRTXT[@]+"${ERRTXT[@]}"}; then
    echo "claude-lane: AUTH FAILURE on lane $EMAIL — the setup token is unusable; retrying cannot help." >&2
    echo "claude-lane: run claude setup-token while signed into $EMAIL" >&2
    echo "claude-lane: then run ai-lanes enroll $EMAIL" >&2
    exit 5
  fi
  if grep -qiE "usage limit|session limit|weekly limit|5-hour limit|limit reached|out of extra usage" \
      ${ERRTXT[@]+"${ERRTXT[@]}"}; then
    if [ "$AUTO" = 1 ] && [ $attempt -le $MAX_RETRIES ]; then
      OLD_EMAIL=$EMAIL
      echo "claude-lane: lane $OLD_EMAIL hit a hard limit; re-picking (attempt $attempt/$MAX_RETRIES)" >&2
      if pick_lane && [ "$EMAIL" != "$OLD_EMAIL" ] && fetch_token; then
        continue
      fi
      echo "claude-lane: no alternate lane available" >&2
    fi
    echo "claude-lane: LANE LIMITED (rc=$rc) — re-dispatch with -A or wait for the reset (claude-pick --json --all)." >&2
    exit 4
  fi
  if [ $attempt -le $MAX_RETRIES ] && grep -qiE \
      "rate limit|too many requests|429|overloaded|capacity|disconnect|connection|ECONN|ETIMEDOUT|timed? ?out|temporarily|internal server error|50[023]|529" \
      ${ERRTXT[@]+"${ERRTXT[@]}"}; then
    wait_s=$((BACKOFF_BASE * attempt))
    echo "claude-lane: transient failure (rc=$rc), retry $attempt/$MAX_RETRIES in ${wait_s}s: $(grep -m1 -ioE 'rate limit|too many requests|429|overloaded|capacity|disconnect|connection[a-z ]*|ECONN[A-Z]*|ETIMEDOUT|timed? ?out|temporarily|internal server error|50[023]|529' ${ERRTXT[@]+"${ERRTXT[@]}"} | head -1)" >&2
    sleep "$wait_s"
    continue
  fi
  echo "claude-lane: FAILED rc=$rc attempt=$attempt lane=$EMAIL (out_bytes=$(wc -c <"$OUT_FILE" | tr -d ' ')); stderr tail:" >&2
  tail -3 "$ERR_FILE" >&2
  [ -s "$RAW_FILE" ] && jq -r '.result // empty' "$RAW_FILE" 2>/dev/null | tail -2 >&2
  [ "$rc" -eq 0 ] && rc=1
  exit "$rc"
done
